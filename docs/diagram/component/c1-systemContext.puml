  @startuml P2P_Node_Context                                                                                                                                              
  !define C4P
  !include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml                                                                           
                                                                                                                                                                          
  LAYOUT_LEFT_RIGHT()
                                                                                                                                                                          
  skinparam rectangle {                                                                                                                                                 
    <<person>>    BackgroundColor #B3E5FC FontColor Black
    <<system>>    BackgroundColor #C8E6C9 FontColor Black                                                                                                                 
    <<external>>  BackgroundColor #CFD8DC FontColor Black
  }                                                                                                                                                                       
                                                                                                                                                                        
  skinparam database {                                                                                                                                                    
    <<external>>  BackgroundColor #FFCDD2 FontColor Black                                                                                                               
  }                                                                                                                                                                       
   
  AddElementTag("peer",    $bgColor="#B3E5FC", $fontColor="Black")                                                                                                        
  AddElementTag("node",    $bgColor="#C8E6C9", $fontColor="Black")                                                                                                      
  AddElementTag("storage", $bgColor="#FFCDD2", $fontColor="Black")                                                                                                        
  AddElementTag("clock",   $bgColor="#FFEB3B", $fontColor="Black")                                                                                                      
  AddElementTag("metrics", $bgColor="#B2EBF2", $fontColor="Black")                                                                                                        
                                                                                                                                                                        
  Person(peer,    "Peer Node",                       "Another node in the P2P network",          $tags="peer")                                                            
  System(p2pNode, "P2P Node",                        "Nodes participating in the blockchain",    $tags="node")                                                          
  System_Ext(dht, "Distributed Hash Table (DHT)",    "Persistent block storage",                $tags="storage")                                                          
  System_Ext(clock,   "Hybrid logical clock service","Provides logical timestamps",             $tags="clock")                                                            
  System_Ext(monitor, "Metrics / Monitoring",        "Collects performance and security metrics",$tags="metrics")                                                         
                                                                                                                                                                          
  Rel(peer,    p2pNode, "Message (INV, GET_BLOCK, BLOCK, REJECT)", "TCP/UDP")                                                                                             
  Rel(p2pNode, dht,     "Read / Write Block & State")                                                                                                                     
  Rel(p2pNode, clock,   "Current HLC request")                                                                                                                            
  Rel(p2pNode, monitor, "Push metrics")
                                                                                                                                                                          
  @enduml           