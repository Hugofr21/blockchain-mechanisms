@startuml AuthenticationFlow
title P2P Join Process: Authentication, Secure Tunnel (ECDHE) & Discovery
skinparam roundCorner 10
skinparam sequenceMessageAlign center
skinparam participantBorderColor #005A9C
skinparam participantBackgroundColor #E0F0FF
autonumber

box "Local Peer (My Node)" #F9F9F9
    participant "Peer" as P
    participant "Handshake\nUtility" as HS
    participant "Connection\nHandler" as CH
    participant "Secure\nSession" as SEC
    participant "Reputation\nManager" as REP
    participant "Routing\nTable" as RT
    participant "ChainSync\nManager" as SYNC
    participant "Kademlia\nNetwork" as KAD
end box

box "Remote Network" #EFEFEF
    participant "Bootstrap\nNode" as B
end box

group "Phase 1 – Cryptographic Authentication & Secure Tunnel (ECDH + AES-GCM)"
    P -> P : new Socket(bootstrapIP)
    P -> CH : new ConnectionHandler(socket)
    activate CH

    P -> HS : doHandshake(CH)
    activate HS

    HS -> HS : generateEphemeralKeys(ECDH)
    HS -> CH : send(HELLO)
    note right of CH: Payload: pubKeyA, clientNonce, \nephemeralPubKeyA
    CH -> B : [TCP Plaintext] HELLO

    B -> B : generateEphemeralKeys(ECDH)
    B --> CH : [TCP Plaintext] HELLO_RESPONSE
    note left of B: Payload: pubKeyB, challengeB, \nephemeralPubKeyB

    CH --> HS : receive(HELLO_RESPONSE)

    HS -> HS : computeSharedSecret(ephemeralPrivA, ephemeralPubB)
    HS -> CH : enableSecureTransport(sharedSecret)
    CH -> SEC ** : init(sharedSecret, AES-256)
    
    note over HS, SEC
        Tunnel is now locked. All subsequent 
        traffic will use AES-GCM encryption.
    end note

    HS -> HS : sign(challengeB)
    HS -> CH : sendSecureMessage(HELLO_ACK)
    CH -> SEC : encrypt(HELLO_ACK, Nonce)
    SEC --> CH : ciphertext + GCM Tag
    CH -> B : [TCP Encrypted AES-GCM] HELLO_ACK

    B -> B : verify signature & encrypt ACK
    B --> CH : [TCP Encrypted AES-GCM] HELLO_ACK
    CH -> SEC : decrypt(ciphertext, GCM Tag)
    SEC --> CH : plaintext payload
    CH --> HS : finalConfirm
    
    HS -> HS : validateRemoteIdentity(PoW, Signature)
    alt Invalid Identity/PoW
        HS --> P : throw SecurityException
        P -> CH : close()
    else Valid Identity
        HS --> P : Optional.of(RemoteNode(B))
    end
    deactivate HS
end

group "Phase 2 – Reputation Registration"
    P -> REP : reportEvent(B, PING_SUCCESS)
    activate REP
    note right of REP
        Initialise reputation score.
        TrustFactor > 0.1
    end note
    REP --> P : ok
    deactivate REP

    P -> RT : updateNode(B)
    activate RT
    RT -> REP : getTrustFactor(B)
    RT -> RT : addOrUpdate(B)
    deactivate RT

    P -> CH : startReaderThread(run)
    note right of CH
        Thread starts intercepting 
        AES-GCM messages
    end note
end

group "Phase 3 – Chain Height Check (Over Secure Tunnel)"
    P -> SYNC : startInitialSync(CH)
    activate SYNC

    SYNC -> CH : sendMessageToPeer(GET_STATUS)
    CH -> SEC : encrypt()
    CH -> B : [TCP Encrypted AES-GCM] GET_STATUS
    B --> CH : [TCP Encrypted AES-GCM] STATUS_RESPONSE
    CH -> SEC : decrypt()
    
    CH --> SYNC : handleResponse(...)
    SYNC -> SYNC : compareHeights()
    opt Remote height > local height
        SYNC -> CH : sendMessageToPeer(GET_BLOCK, topHash)
        CH -> B : [TCP Encrypted AES-GCM] GET_BLOCK
        note right of SYNC
            Initiate reverse download
            (missing parents)
        end note
    end
    deactivate SYNC
end

group "Phase 4 – Network Discovery (Bootstrap Over Secure Tunnel)"
    P -> KAD : triggerBootstrapLookup()
    activate KAD

    KAD -> CH : sendMessageToPeer(FIND_NODE)
    CH -> SEC : encrypt()
    CH -> B : [TCP Encrypted AES-GCM] FIND_NODE
    B --> CH : [TCP Encrypted AES-GCM] NODES_RESPONSE
    CH -> SEC : decrypt()

    CH --> KAD : return list<Node>

    loop for each neighbour
        KAD -> REP : reportEvent(neighbour, FIND_NODE_USEFUL)
        KAD -> RT  : updateNode(neighbour)
        note right of KAD
            Populate routing table
            with new peers securely
        end note
    end
    deactivate KAD
end

@enduml