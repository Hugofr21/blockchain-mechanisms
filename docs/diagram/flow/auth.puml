@startuml
title P2P Join Process: Authentication, Reputation & Discovery
skinparam roundCorner 10
skinparam sequenceMessageAlign center
skinparam participantBorderColor #005A9C
skinparam participantBackgroundColor #E0F0FF
autonumber


box "Local Peer (My Node)" #F9F9F9
    participant "Peer" as P
    participant "Handshake\nUtility" as HS
    participant "Reputation\nManager" as REP
    participant "Routing\nTable" as RT
    participant "ChainSync\nManager" as SYNC
    participant "Kademlia\nNetwork" as KAD
    participant "Connection\nHandler" as CH
end box

box "Remote Network" #EFEFEF
    participant "Bootstrap\nNode" as B
end box


group "Phase1 – Cryptographic Authentication"
    P -> P : new Socket(bootstrapIP)
    P -> CH : new ConnectionHandler(socket)
    activate CH

    P -> HS : doHandshake(CH)
    activate HS


    HS -> CH : send(HELLO(pubKeyA, clientNonce))
    CH -> B : [TCP] HELLO(pubKeyA, clientNonce)


    B -> B : generate(challengeB)
    B -> B : sign(HELLO(pubKeyA, clientNonce, challengeB))
    B --> CH : [TCP] HELLO_RESPONSE(pubKeyB, challengeB, signatureB)

    CH --> HS : receive(HELLO_RESPONSE(...))

    HS -> HS : validateRemoteSignature()
    alt Invalid signature
        HS --> P : throw SecurityException
        P -> CH : close()
        deactivate CH
    else Valid signature

        HS -> HS : sign(challengeB)
        HS -> CH : send(ACK(signedChallengeB))
        CH -> B : [TCP] ACK(signedChallengeB)


        B -> B : verify(signedChallengeB)
        alt verification fails
            B --> CH : [TCP] AUTH_FAILURE
            CH --> HS : error
            HS --> P : Optional.empty()
        else verification ok
            B --> CH : [TCP] AUTH_SUCCESS
            CH --> HS : success payload
            HS --> P : Optional.of(RemoteNode(B))
        end
    end
    deactivate HS
    deactivate CH
end


group "Phase2 – Reputation Registration"
    P -> REP : reportEvent(B, PING_SUCCESS)
    activate REP
    note right of REP
        Initialise reputation score.
        TrustFactor > 0.1
    end note
    REP --> P : ok
    deactivate REP

    P -> RT : updateNode(B)
    activate RT
    RT -> REP : getTrustFactor(B)
    RT -> RT : addOrUpdate(B)
    note right of RT
        Node accepted because
        handshake proved identity.
    end note
    deactivate RT

    P -> CH : startReaderThread()
    activate CH
    deactivate CH
end


group "Phase3 – Chain Height Check"
    P -> SYNC : startSync(CH)
    activate SYNC

    SYNC -> CH : send(GET_STATUS)
    CH -> B : [MSG] GET_STATUS
    B --> CH : [MSG] STATUS_RESPONSE(height, topHash)

    CH --> SYNC : handleResponse(...)
    SYNC -> SYNC : compareHeights()
    opt Remote height > local height
        SYNC -> CH : send(GET_BLOCK, topHash)
        note right of SYNC
            Initiate reverse download
            (missing parents)
        end note
    end
    deactivate SYNC
end


group "Phase4 – Network Discovery (Bootstrap)"
    P -> KAD : findNode(myNodeId)
    activate KAD

    KAD -> CH : send(FIND_NODE, target=myNodeId)
    CH -> B : [MSG] FIND_NODE
    B --> CH : [MSG] NODES_RESPONSE(list<Node>)

    CH --> KAD : return list<Node>

    loop for each neighbour
        KAD -> REP : reportEvent(neighbour, FIND_NODE_USEFUL)
        KAD -> RT  : updateNode(neighbour)
        note right of KAD
            Populate routing table
            with new peers
        end note
    end
    deactivate KAD
end

@enduml
