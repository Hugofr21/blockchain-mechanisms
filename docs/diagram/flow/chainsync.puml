@startuml Chaiba P2P Blockchain: State Sync & Block Gossip
title P2P Blockchain: State Sync, Batch Download & Block Gossip
skinparam sequenceMessageAlign center
skinparam round corner 10
skinparam participantBorderColor #005A9C
skinparam participantBackgroundColor #E0F0FF
autonumber

box "Peers" #F8F8F8
    participant "Remote Peer (R)" as R
    participant "Local Node (L)" as L
    participant "Other Peers (O)" as O
end box

participant "Kademlia DHT" as DHT

group Phase 1 – Anti-Entropy & Initial Sync (Batch)
    L -> R : GET_STATUS
    activate R
    note over R
        ChainSyncUseCase:
        Reads local tip (last block)
    end note
    R --> L : CHAIN_STATUS_RESPONSE(topHash, remoteHeight)
    deactivate R

    activate L
    L -> L : handleStatusResponse()
    note right of L
        Compare state:
        1. isBehind = remoteHeight > localHeight
        2. isFork = (remoteHeight == localHeight) && (remoteHash != localHash)
    end note

    alt isFork detected
        note right of L: Hash mismatch at same height.\nStep back to find common ancestor.
        L -> R : GET_BLOCKS_BATCH(requestFrom = localHeight - 1)
    else isBehind detected
        note right of L: Local node is delayed.
        L -> R : GET_BLOCKS_BATCH(requestFrom = localHeight)
    else Synchronized
        note right of L: State matches. No action needed.
    end

    opt If BATCH_REQUEST was sent
        activate R
        note over R: Collects up to 20 blocks\nin chronological order
        R --> L : BLOCK_BATCH(List<Block>)
        deactivate R

        L -> L : handleBlockBatch()
        note right of L
            Process blocks sequentially.
            If batch is full (20 blocks),
            request next batch automatically.
        end note
    end
    deactivate L
end

== ==

group Phase 2 – Live Gossip (Real-Time Propagation)
    R -> L : INV_DATA(InventoryType.BLOCK, hash=X)
    activate L
    note right of L
        BlockEventUseCase:
        Check if Block X is in BlockStore
    end note

    alt Block X already stored
        ' do nothing
    else Block X unknown
        group Download (Request Single Block)
            L -> R : GET_BLOCK(hash=X)
            activate R
            R --> L : BLOCK(fullBlockData)
            deactivate R
        end

        group Processing & Consensus (BlockRule)
            L -> L : BlockRule.receiveBlock(X)
            
            alt Block is VALID (Added to Main Chain)
                L -> L : TransactionRule.cleanPool()
                note right of L
                    onBlockCommitted fired
                    Triggers async mining if Mempool is still full
                end note

                par Gossip (Broadcast)
                    L -> O : INV_DATA(BLOCK, hash=X)
                end

            else FORK DETECTED (Concurrent Mining)
                L -> L : executeChainReorganization()
                note right of L
                    1. Rewind to common ancestor
                    2. Apply new longer branch
                    3. Return dead txs to Mempool
                    4. Notify State Machine (Rollback)
                end note

            else MISSING_PARENT (Orphan Block)
                note right of L
                    Block buffered in orphan list.
                    Missing ancestor detected.
                end note
                
                L -> R : GET_BLOCK(hash=parentOfX)
                
                par Fallback Recovery
                    L -> DHT : findValue(hash=parentOfX)
                end

            else INVALID Block
                L -> L : discard()
                note right of L
                    Penalize sender reputation (PING_FAIL / INVALID_BLOCK)
                end note
            end
        end
    end
    deactivate L
end
@enduml