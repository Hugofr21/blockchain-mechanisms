@startuml architecture_spa_direct_auth

title Distributed Ledger Network (SPA Direct Auth Pattern) & Telemetria

skinparam shadowing false
skinparam componentStyle rectangle
skinparam defaultTextAlignment center
skinparam linetype ortho
skinparam nodesep 60
skinparam ranksep 80
skinparam pad 20

skinparam node {
  BackgroundColor<<public>> #FFFFFF
  BackgroundColor<<gateway>> #B3E5FC
  BackgroundColor<<security>> #D1C4E9
  BackgroundColor<<adapter>> #FFEB3B
  BackgroundColor<<app>> #C8E6C9
  BackgroundColor<<infra>> #CFD8DC
  BackgroundColor<<storage>> #FFCDD2
  BackgroundColor<<metrics>> #B2EBF2
  FontColor Black
}

skinparam component {
  BackgroundColor<<public>> #FFFFFF
  BackgroundColor<<gateway>> #B3E5FC
  BackgroundColor<<security>> #D1C4E9
  BackgroundColor<<adapter>> #FFEB3B
  BackgroundColor<<app>> #C8E6C9
  BackgroundColor<<infra>> #CFD8DC
  BackgroundColor<<storage>> #FFCDD2
  BackgroundColor<<metrics>> #B2EBF2
  FontColor Black
}

skinparam database {
  BackgroundColor<<storage>> #FFCDD2
  FontColor Black
}

node "Ambiente Externo (Internet)" as public {
  component "Single Page Application\n(React SPA)" <<app>> as react
}

node "Identity Provider" as idp {
  component "Keycloak Server\n(OIDC / OAuth2)" <<security>> as keycloak
}

node "DMZ / Public Zone" <<gateway>> as dmz {
  node "API Gateway\n(Reverse Proxy & Ingress)" <<gateway>> as apigw {
    component "Rate Limiter & Logging" <<adapter>> as ratelimit
    component "JWT Validator\n(Resource Server)" <<security>> as auth
    component "API Router\n(REST / RPC)" <<gateway>> as api
  }
}

node "Private Network\n(Isolated Subnet)" <<infra>> as privNet {
  node "Bootstrap Node\n(Seed Peer)" <<infra>> as bootstrap {
    component "DHT Service\n(Kademlia Routing)" <<app>> as bootDHT
    component "Ledger Core" <<storage>> as bootLedger
  }

  node "Peer Node A\n(Validator)" <<infra>> as peerA {
    component "DHT Service\n(Kademlia Routing)" <<app>> as dhtA
    component "Ledger Core" <<storage>> as ledgerA
  }

  node "Peer Node B\n(Validator)" <<infra>> as peerB {
    component "DHT Service\n(Kademlia Routing)" <<app>> as dhtB
    component "Ledger Core" <<storage>> as ledgerB
  }
}

node "Observability Stack" <<metrics>> as obs {
  component "OpenTelemetry\nCollector" <<metrics>> as otel
  database "Prometheus\nServer" <<storage>> as prometheus
  component "Grafana\nDashboard" <<metrics>> as grafana
}

react <--> keycloak : 1. Autenticação OIDC (SPA PKCE Flow)\nRetorna JWT Access Token
react --> ratelimit : 2. Requisição HTTP API\n(Injeta JWT Bearer Header)
ratelimit --> auth : 3. Validação de Tráfego
auth --> api : 4. Verificação de Assinatura e Claims (JWT)

api --> peerA : 5. RPC Autorizado (Submit Tx)
api --> peerB : 5. RPC Autorizado (Submit Tx)

bootDHT <-right-> dhtA : Kademlia RPC
bootDHT <-right-> dhtB : Kademlia RPC
dhtA <-right-> dhtB : Sync Routing Table

apigw .....> otel : Export OTLP
bootstrap .....> otel : Export OTLP
peerA .....> otel : Export OTLP
peerB .....> otel : Export OTLP

otel --> prometheus : Scrape Metrics
prometheus --> grafana : Consultas PromQL

@enduml