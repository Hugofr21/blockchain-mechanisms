@startuml
title Private DHT Ledger Network with API Gateway and Bootstrap Node

skinparam shadowing false
skinparam componentStyle rectangle
skinparam defaultTextAlignment center

node "Client Network\n(External)" as clientNet {
  actor "User / Client" as client
}

node "DMZ / Public Zone" as dmz {
  node "API Gateway\n(Reverse Proxy)" as apigw {
    component "1. Rate Limiter\n& Logging" as ratelimit
    component "2. Auth Module\n(Keycloak / JWT)" as auth
    component "3. API Router\n(REST / RPC)" as api
  }
}

node "Private Network\n(Isolated Subnet)" as privNet {

  node "Bootstrap Node\n(Seed Peer)" as bootstrap {
    component "DHT Service\n(Kademlia Routing)" as bootDHT
    component "Ledger Core\n(Block Validation)" as bootLedger
    database "Local Chain Storage" as bootStorage
  }

  node "Peer Node A\n(Validator)" as peerA {
    component "DHT Service\n(Kademlia Routing)" as dhtA
    component "Ledger Core\n(Mining / Consensus)" as ledgerA
    database "Local Chain Storage" as storeA
  }

  node "Peer Node B\n(Validator)" as peerB {
    component "DHT Service\n(Kademlia Routing)" as dhtB
    component "Ledger Core\n(Mining / Consensus)" as ledgerB
    database "Local Chain Storage" as storeB
  }

  node "Peer Node C\n(Validator)" as peerC {
    component "DHT Service\n(Kademlia Routing)" as dhtC
    component "Ledger Core\n(Mining / Consensus)" as ledgerC
    database "Local Chain Storage" as storeC
  }
}

client --> ratelimit : HTTPS Requests
ratelimit --> auth : Tráfego Permitido
auth --> api : Token Validado

api --> peerA : Private RPC\n(Submit Tx / Read)
api --> peerB : Private RPC\n(Submit Tx / Read)
api --> peerC : Private RPC\n(Submit Tx / Read)

bootDHT <--> dhtA : Kademlia RPC (Discovery)
bootDHT <--> dhtB : Kademlia RPC (Discovery)
bootDHT <--> dhtC : Kademlia RPC (Discovery)

dhtA <--> dhtB : Routing Table Sync
dhtB <--> dhtC : Routing Table Sync
dhtA <--> dhtC : Routing Table Sync

bootLedger --> bootStorage : Persist Blocks
ledgerA --> storeA : Persist Blocks
ledgerB --> storeB : Persist Blocks
ledgerC --> storeC : Persist Blocks

@enduml